# =============================================================================
# Intelligent Hotel Booking System - Docker Environment Variables
# =============================================================================
# Copy this file to .env and customize for your deployment
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# JWT Secret Key (REQUIRED - Change in production!)
# Generate a strong random key: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# -----------------------------------------------------------------------------
# MongoDB Settings (Optional - defaults shown)
# -----------------------------------------------------------------------------

# MongoDB root username
MONGO_INITDB_ROOT_USERNAME=admin

# MongoDB root password (REQUIRED - Change in production!)
MONGO_INITDB_ROOT_PASSWORD=admin123

# MongoDB database name
MONGO_INITDB_DATABASE=intelligent-hotel-booking

# -----------------------------------------------------------------------------
# Backend Settings (Optional - defaults shown)
# -----------------------------------------------------------------------------

# Server port (internal container port)
PORT=3000

# Node environment
NODE_ENV=production

# -----------------------------------------------------------------------------
# Docker Network Settings (Optional)
# -----------------------------------------------------------------------------

# Host port to expose the application
# Change this if port 3000 is already in use
HOST_PORT=3000
